{
  "name": "@vera/app",
  "version": "0.1.0",
  "description": "Desktop workspace for VERA documents",
  "author": "Kyle Willis",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "predev": "tsc -p tsconfig.json",
    "dev": "concurrently -k --success first \"vite --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -p tsconfig.json && vite build",
    "build:sidecar": "uv run --project ../.. --extra app --with pyinstaller pyinstaller --noconfirm --clean --onedir --name vera-sidecar --distpath build/sidecar --workpath build/pyinstaller --specpath build/pyinstaller src/vera_app/sidecar.py",
    "dist": "npm run build && npm run build:sidecar && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "pdfjs-dist": "^6.0.227",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "dev.vera.desktop",
    "productName": "VERA",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/sidecar/vera-sidecar",
        "to": "python/sidecar"
      },
      {
        "from": "src/vera_app/modes_builtin",
        "to": "python/vera_app/modes_builtin"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
